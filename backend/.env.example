# Healthcare Appointment Backend - Environment Variables

# Server
SERVER_PORT=8080

# Database (H2 file mode for dev, or Postgres for production)
DB_USERNAME=sa
DB_PASSWORD=

# JWT (REQUIRED in production - use a strong 256+ bit secret)
JWT_SECRET=change-me-in-production-use-at-least-256-bit-secret-key-here
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Kafka
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Business rules
CANCELLATION_WINDOW_HOURS=2
IDEMPOTENCY_TTL_HOURS=24
OUTBOX_POLL_INTERVAL_MS=2000
