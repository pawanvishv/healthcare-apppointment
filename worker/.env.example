# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=healthcare-notification-worker
KAFKA_TOPICS=appointment.booked,appointment.cancelled,appointment.rescheduled

# H2 database (shared with Spring Boot backend via TCP AUTO_SERVER)
# Backend must run with AUTO_SERVER enabled (see application-dev.yml)
H2_HOST=localhost
H2_PORT=9093
H2_DB_PATH=./data/appointments
H2_USER=sa
H2_PASSWORD=
# Optional: path to h2-*.jar (auto-detected from Maven cache if omitted)
# H2_JAR_PATH=C:\Users\you\.m2\repository\com\h2database\h2\2.2.224\h2-2.2.224.jar

# Notifications (mock mode logs to console when SMTP is not configured)
NOTIFICATION_MODE=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@healthapp.com

# Worker
LOG_LEVEL=INFO
